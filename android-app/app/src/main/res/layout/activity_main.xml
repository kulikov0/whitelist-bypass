<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A0A0A"
    android:orientation="vertical">

    <!-- Status area -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:gravity="center"
        android:orientation="vertical">

        <View
            android:id="@+id/statusDot"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/status_dot"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отключено"
            android:textColor="#888888"
            android:textSize="18sp"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Connect/Disconnect button -->
    <Button
        android:id="@+id/connectButton"
        android:layout_width="200dp"
        android:layout_height="56dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="48dp"
        android:layout_marginTop="16dp"
        android:background="@drawable/btn_connect"
        android:text="Подключить"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:letterSpacing="0.03" />

    <!-- Debug log (hidden, toggle with long press on status dot) -->
    <TextView
        android:id="@+id/logView"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="#111111"
        android:fontFamily="monospace"
        android:padding="6dp"
        android:scrollbars="vertical"
        android:textColor="#00CC66"
        android:textSize="9sp"
        android:visibility="gone" />

    <!-- WebView runs hidden in background -->
    <WebView
        android:id="@+id/webView"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:visibility="invisible" />

</LinearLayout>
